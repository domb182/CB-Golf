<div id="product-email-signup">
    <h5 class="mb-10"><span id="LaunchDate">Launching {{product.metafields.custom.launch_date | date: "%d/%m"}} at {{product.metafields.custom.launch_date | date: "%l%p"}} GMT</span> - Get Notified</h5>
    <script>
      // Specify the launch date and time in UTC
      const launchDateUTC = "{{product.metafields.custom.launch_date | date }}"; // ISO 8601 format with Z denoting UTC

      // Convert to user's local timezone
      const localLaunchDate = new Date(launchDateUTC);

      // Extract the day, month, and hour in user's local timezone
      const day = localLaunchDate.getDate().toString().padStart(2, "0");
      const month = (localLaunchDate.getMonth() + 1).toString().padStart(2, "0"); // Months are zero-indexed
      const hours = localLaunchDate.getHours();
      const period = hours >= 12 ? "PM" : "AM";
      const formattedHour = hours % 12 || 12; // Convert 24-hour time to 12-hour time

      let timeZoneName = new Intl.DateTimeFormat('en-US', { timeZoneName: 'short' }).format(localLaunchDate).split(", ")[1];
      
      if(timeZoneName == "GMT+1") {
        timeZoneName = "BST";
      }
      // Format the launch date and time
      const formattedLaunchDate = `Launching ${day}/${month} at ${formattedHour}${period} (${timeZoneName})`;

      // Display in the browser
      document.getElementById("LaunchDate").innerText = formattedLaunchDate;
    </script>
    {% form 'customer', class: 'newsletter-form' %}
                  <input type="hidden" name="contact[tags]" value="Product Launch Sign Up, {{product.handle}}">
                  <div class="newsletter-form__field-wrapper">
                    <div class="field d-flex">
                      <input
                        id="NewsletterForm--product-email-signup"
                        type="email"
                        name="contact[email]"
                        class="field__input mb-0"
                        value="{{ form.email }}"
                        aria-required="true"
                        autocorrect="off"
                        autocapitalize="off"
                        autocomplete="email"
                        {% if form.errors %}
                          autofocus
                          aria-invalid="true"
                          aria-describedby="Newsletter-error--product-email-signup"
                        {% elsif form.posted_successfully? %}
                          aria-describedby="Newsletter-success--product-email-signup"
                        {% endif %}
                        placeholder="Email"
                        required
                      >
                      <label class="field__label hidden" for="NewsletterForm--product-email-signup">
                        Signup
                      </label>
                      <button
                        type="submit"
                        class="newsletter-form__button field__button"
                        name="commit"
                        id="Subscribe"
                        aria-label="{{ 'newsletter.button_label' | t }}"
                      >
                        <i>{% render 'icon-theme-007' %}</i>
                      </button>
                    </div>
                    {%- if form.errors -%}
                      <small class="newsletter-form__message form__message" id="Newsletter-error--product-email-signup">
                        {{- form.errors.translated_fields.email | capitalize }}
                        {{ form.errors.messages.email -}}
                      </small>
                    {%- endif -%}
                  </div>
                  {%- if form.posted_successfully? -%}
                    <h3
                      class="newsletter-form__message newsletter-form__message--success form__message"
                      id="Newsletter-success--product-email-signup"
                      tabindex="-1"
                      autofocus
                    >
                      {{- 'newsletter.success' | t }}
                    </h3>
                  {%- endif -%}
                {% endform %}
  </div>