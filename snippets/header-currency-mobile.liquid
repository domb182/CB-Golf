<div id="currency-mobile-header" class="popup-navigation__currency d-lg-none ml-25">
    {% if localization.available_countries.size > 1 %}
        <localization-form>
          {% form 'localization' %}
            <div class="disclosure">
              <button type="button" class="dropdown-button d-flex align-items-center position-lg-relative h-auto p-0 border-0 cursor-pointer disclosure__button" aria-expanded="false" aria-controls="CountryList">
                {{ localization.country.currency.symbol }}
      
                <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret ml-10" viewBox="0 0 10 6" >
                  <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
                </svg>
              </button>
      
              <ul id="CountryList" role="list" class="disclosure__list list-unstyled" hidden>
                <button class="h-auto p-10 border-0 cursor-pointer disclosure__button" aria-expanded="false" aria-controls="CountryList">
                    Close
                </button>
                {% assign popular-currency = "GB,US,CA,AU,DE,NZ,KR" | split: "," %}
                {% for country in localization.available_countries %}
                    {% if popular-currency contains country.iso_code %}
                        {% unless country.iso_code == localization.country.iso_code %}
                            <li class="disclosure__item" tabindex="-1">
                                <a href="#"{% if country.iso_code == localization.country.iso_code %} aria-current="true"{% endif %} data-value="{{ country.iso_code }}">
                                {{ country.name }}
                                </a>
                            </li>
                        {% endunless %}
                    {% endif %}
                {% endfor %}
                <li class="disclosure__item" tabindex="-1"> -- </li>
                {% for country in localization.available_countries %}
                    {% unless popular-currency contains country.iso_code %}
                    <li class="disclosure__item" tabindex="-1">
                        <a href="#"{% if country.iso_code == localization.country.iso_code %} aria-current="true"{% endif %} data-value="{{ country.iso_code }}">
                        {{ country.name }}
                        </a>
                    </li>
                {% endunless %}
                {% endfor %}
              </ul>
      
              <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
            </div>
          {% endform %}
        </localization-form>
      {% endif %}
      
</div>