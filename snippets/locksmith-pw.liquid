{% assign min = 1 %}
{% assign max = 3 %}
{% assign diff = max | minus: min %}
{% assign randomNumber = "now" | date: "%N" | modulo: diff | plus: min %}
<script async type="text/javascript" src="https://static.klaviyo.com/onsite/js/klaviyo.js?company_id=Ry5qcM"></script>

<div class="h-100 col-12 d-flex justify-content-center flex-center flex-column justify-content-around bgImage">
    <div class="password-header d-flex justify-content-center flex-center flex-column justify-content-around">
      <div class="logo h6 w-50 m-0 text-hide">
      <a href="{{ routes.root_url }}" class="d-block text-hide">
        {% render 'svg-logo-mobile' %}
         {{- shop.name -}}
      </a>
    </div>
    
    <div class="password-content d-flex flex-center flex-fill flex-column">
      <div class="password-page-content py-50">
        
        <div class="password-logo text-light mt-40 text-center">
            {% if heading %}
              <h2>{{ heading }}</h2>
            {% endif %}
          <p class="success_message mb-0"></p>
        </div>
        {% if signup == "true" %}
          {% form 'customer', class: 'newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="Product Launch Sign Up, locksmith">
            <div class="newsletter-form__field-wrapper locksmith-signup text-center text-light">
              <p>Get Early Access</p>
              <div class="field d-flex">
                <input
                  id="NewsletterForm--product-email-signup"
                  type="email"
                  name="contact[email]"
                  class="field__input mb-0"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  {% if form.errors %}
                    autofocus
                    aria-invalid="true"
                    aria-describedby="Newsletter-error--product-email-signup"
                  {% elsif form.posted_successfully? %}
                    aria-describedby="Newsletter-success--product-email-signup"
                  {% endif %}
                  placeholder="Email"
                  required
                >
                <label class="field__label hidden" for="NewsletterForm--product-email-signup">
                  Signup
                </label>
                <button
                  type="submit"
                  class="newsletter-form__button field__button"
                  name="commit"
                  id="Subscribe"
                  aria-label="{{ 'newsletter.button_label' | t }}"
                >
                  <i>{% render 'icon-theme-007' %}</i>
                </button>
              </div>
              {%- if form.errors -%}
                <small class="newsletter-form__message form__message" id="Newsletter-error--product-email-signup">
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </small>
              {%- endif -%}
            </div>
            {%- if form.posted_successfully? -%}
              <h3
                class="newsletter-form__message newsletter-form__message--success form__message"
                id="Newsletter-success--product-email-signup"
                tabindex="-1"
                autofocus
              >
                {{- 'newsletter.success' | t }}
              </h3>
            {%- endif -%}
          {% endform %}
        {% endif %}
      </div>
      
    
      
    {% if type == "passcode" %}
        <div class="locksmith-passcode-container container page-width d-flex flex-center">
          <a id="passcode" onclick="open_passcode()" class="btn h2 text-center">Enter Passcode</a>
          <form id="locksmith_passcode_form2" class="hidden">
            <div class="passcode-content overlay-content">
              <div class="password-contact-header text-light d-flex justify-content-between">
                <h2>PASSCODE</h2><span onclick="close_all_pop()" class="closeFAQ text-light">CLOSE</span>
            </div>
              <p><input placeholder="code" id="locksmith_passcode" class="locksmith-passcode {% if locksmith_passcode_attempted %}failed{% endif %}"></p>
              <p><button type="submit" class="button button-primary btn btn-primary action-button action_button">ENTER</button></p>
            </div>
          </form>
        </div>

        <script>
          var passcodeForm = document.getElementById("locksmith_passcode_form2");
          passcodeForm.addEventListener('submit', function (event) {
            event.preventDefault();
            var passcode = document.getElementById("locksmith_passcode").value;
            /* REMOVE THIS LINE and insert any desired transforms to passcode here */
            Locksmith.submitPasscode(passcode, event);
          });
        </script>
    {% endif %}
      
      
    </div>
    {% comment %} <div class="password-footer">
        <div class="footer-logo">
          <div class="footer-navigation text-light">
            <ul class="d-flex justify-content-center flex-center flex-row justify-content-around mb-20 flex-wrap gap-5">
              <li><a onclick="open_about()">ABOUT </a></li>
              <li><a href="/account">ACCOUNT</a></li>
              <li><a target="_blank" href="https://360.postco.co/uvuclub">RETURNS</a></li>
              <li><a onclick="open_contact()">CONTACT </a></li>
              <li><a href="https://www.instagram.com/uvu/">INSTAGRAM</a></li>
              <li><a href="https://www.tiktok.com/@uvuclub">TIKTOK</a></li>
              {% comment %} <li><a href="https://discord.gg/gBuzeP3Teg">DISCORD</a></li> {% endcomment %}
            </ul>
          </div>
        </div>
      </div> {% endcomment %}
  </div>

  <script>
    function open_passcode(){
      document.getElementById("locksmith_passcode_form2").classList.remove("hidden");
    }
    
    function close_all_pop(){
        document.getElementById("locksmith_passcode_form2").classList.add("hidden");
    }   
  </script>
  
  <style>
    #locksmith_passcode_form2{
    color: #fff;
    flex:1;
    position: fixed;
    top: 0px;
    left: 0px;
    z-index: 2;
    background: black;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .overlay-content {
    max-width: 450px;
    width: 100%;
    padding: 2em;
  }
  .closeFAQ,
  .locksmith-signup button{
    cursor: pointer;
  }
    svg {
      fill: #fff;
    }
    #header,
    .shopify-section-group-footer-group {
      display: none;
    }
    #MainContent {
      background-color: #000;
      height: 100dvh;
      display: flex;
      align-items: center;
      flex-direction: column;
    }
    .bgImage {
      background-image: url('{{ bgImage }}');
      background-size: cover;
      background-position: center;
    }
    #locksmith-content {
      height: 100vh;
      width: 100%;
      .section.spacing-style {
        padding: 0;
        margin: 0;
      }
      .locksmith-content-inner {
        max-width: none !important;
        padding: 0 !important;
        height: 100vh !important;
      }
  }
  
  input[type=email] {
    min-width: 280px !important;
  }
  
  
  
.locksmith-passcode {
  font-size: 16px;
  height: 40px;
}
  
  div:empty {
    display: none !important;
}
  
  .text-light a:visited, .text-light a:active, .text-light a:link { 
    color: #fff;
    }
    #countdown ul,
    #countdown li,
  #countdown li span  {
    font-size: 2.5rem;
    line-height: 1.2em;
  }
  .locksmith-signup .field__input {
    border: 0 !important;
  }
  .locksmith-signup button,
  .locksmith-signup .field__input:hover,
  .locksmith-signup .field__input:focus {
    background: white;
    background-color: var(--input-bg);
    border: var(--input-bd);
    color: var(--input-c);
    border-left: 0;
  }
  </style>
  