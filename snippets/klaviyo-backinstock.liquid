{% if product.metafields.custom.restock_able == true %}
    {% comment %} klaviyo back in stock {% endcomment %}
    <script src="https://a.klaviyo.com/media/js/onsite/onsite.js"></script>
    <script>
        var klaviyo = klaviyo || [];
        klaviyo.init({
        account: "Ry5qcM",
        list: "ThtfQV",
        platform: "shopify"
        });
        klaviyo.enable("backinstock",{ 
        trigger: {
        product_page_text: "{{ 'products.product.klaviyo.oos_button' | t }}",
        product_page_class: "button",
        product_page_text_align: "center",
        product_page_margin: "0px",
        replace_anchor: false
        },
        modal: {
        headline: "{product_name}",
        body_content: "{{ 'products.product.klaviyo.oos_msg' | t }}",
        email_field_label: "{{ 'products.product.klaviyo.email' | t }}",
        button_label: "{{ 'products.product.klaviyo.button_label' | t }}",
        subscription_success_label: "{{ 'products.product.klaviyo.subscription_success_label' | t }}",
        newsletter_subscribe_label: "{{ 'products.product.klaviyo.newsletter_subscribe_label' | t }}",
        close_label:"{{ 'products.product.klaviyo.close_label' | t }}",
        footer_content: '',
        drop_background_color: "#000",
        background_color: "#fff",
        text_color: "#222",
        button_text_color: "#fff",
        button_background_color: "#000000",
        close_button_color: "#ccc",
        error_background_color: "#fcd6d7",
        error_text_color: "#C72E2F",
        success_background_color: "#d3efcd",
        success_text_color: "#1B9500"
        }
    });
    
    </script>
{% endif %}